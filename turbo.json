{
    "$schema": "https://v2-9-6.turborepo.dev/schema.json",
    "ui": "stream",
    "globalEnv": ["CONTEXT_PATH"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [
                ".next/**",
                "!.next/cache/**",
                "bun-dist/**",
                "build/**",
                "app/**",
                "bundle/**"
            ]
        },
        "deploy": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"]
        },
        "build:standalone": {
            "dependsOn": [],
            "outputs": ["build/**"]
        },
        "lint": {
            "dependsOn": ["^lint"]
        },
        "check-types": {
            "dependsOn": ["^check-types"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "publish:app-hub": {
            "dependsOn": ["build"]
        },
        "format:check": {
            "dependsOn": ["^format:check"]
        },
        "lint:check": {
            "dependsOn": ["^lint:check"]
        }
    }
}
