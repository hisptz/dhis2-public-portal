{
    "name": "manager",
    "version": "1.5.5",
    "description": "",
    "license": "BSD-3-Clause",
    "private": true,
    "scripts": {
        "build": "tsr generate &&  d2-app-scripts build --no-verify",
        "dev": "concurrently -c blue,green --names routes,app 'tsr watch'  'dotenv -- cross-var d2-app-scripts start --proxy %DHIS2_PROXY_URL% --port 3001'",
        "test": "d2-app-scripts test --passWithNoTests",
        "deploy": "d2-app-scripts deploy",
        "bd": "pnpm run build && dotenv -- cross-var pnpm run deploy  %DHIS2_PROXY_URL%",
        "publish:app-hub": "d2-app-scripts publish",
        "test:e2e": "concurrently --kill-others --success first -c blue,green --names app,cypress 'pnpm run dev'  'cypress run'",
        "test:e2e-open": "concurrently -c blue,green --names app,cypress 'pnpm run dev'  'cypress open'",
        "check-types": "tsc --noEmit",
        "lint:check": "eslint .",
        "format:check": "prettier -v --check ."
    },
    "devDependencies": {
        "@dhis2/cli-app-scripts": "^12.11.0",
        "@dhis2/cypress-commands": "^10.0.6",
        "@dhis2/cypress-plugins": "^10.0.6",
        "@tailwindcss/cli": "^4.1.4",
        "@tailwindcss/vite": "^4.1.13",
        "@tanstack/router-cli": "^1.149.3",
        "@tanstack/router-devtools": "^1.149.3",
        "@tanstack/router-plugin": "^1.149.3",
        "@types/jest": "^29.5.14",
        "@types/jszip": "^3.4.1",
        "@types/node": "^24.3.3",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "concurrently": "^9.1.2",
        "cross-var": "^1.1.0",
        "cypress": "^15.11.0",
        "dotenv": "^16.5.0",
        "dotenv-cli": "^8.0.0",
        "tailwind": "4",
        "tailwindcss": "4",
        "typescript": "5.6.3",
        "vite": "^8.0.8"
    },
    "dependencies": {
        "@dhis2/app-runtime": "3.16.0",
        "@dhis2/d2-i18n": "^1.1.3",
        "@dhis2/ui": "^10.9.0",
        "@hello-pangea/dnd": "^18.0.1",
        "@hisptz/dhis2-analytics": "^2.1.35",
        "@hisptz/dhis2-ui": "^2.0.52",
        "@hisptz/dhis2-utils": "^2.0.19",
        "@hookform/resolvers": "^5.2.2",
        "@packages/shared": "workspace:*",
        "@react-pdf-viewer/core": "^3.12.0",
        "@tanstack/react-query": "4.44.0",
        "@tanstack/react-router": "^1.149.3",
        "@types/lodash-es": "^4.17.12",
        "@types/react-dom": "^19.1.2",
        "classnames": "^2.5.1",
        "cypress-file-upload": "^5.0.8",
        "cypress-real-events": "^1.14.0",
        "dompurify": "^3.3.3",
        "exceljs": "^4.4.0",
        "file-saver": "^2.0.5",
        "framer-motion": "^12.34.0",
        "highcharts": "^12.4.0",
        "highcharts-react-official": "^3.2.2",
        "html-truncate": "^1.2.2",
        "jszip": "^3.10.1",
        "leaflet": "^1.9.4",
        "lodash-es": "^4.18.1",
        "luxon": "^3.7.2",
        "react": "18.3.1",
        "react-countup": "^6.5.3",
        "react-dom": "18.3.1",
        "react-error-boundary": "^6.0.0",
        "react-full-screen": "^1.1.1",
        "react-grid-layout": "^2.2.2",
        "react-hook-form": "^7.57.0",
        "react-jsx-parser": "^2.4.0",
