{
    "name": "portal",
    "version": "1.5.5",
    "private": true,
    "scripts": {
        "dev": "bun --bun next dev",
        "build": "bun --bun next build",
        "postbuild": "./postbuild.sh",
        "build:standalone": "./build.sh",
        "start": "CONTEXT_PATH=/dashboard bun --bun server/start.js",
        "lint": "next lint",
        "check-types": "next typegen &&  tsc --noEmit",
        "test:e2e": "dotenv -- cross-var concurrently --kill-others --success first -c blue,green --names app,cypress 'yarn dev' 'cypress run'",
        "test:e2e-open": "dotenv -- cross-var concurrently -c blue,green --names app,cypress 'yarn dev'  'cypress open'",
        "lint:check": "eslint .",
        "format:check": "prettier --check ."
    },
    "dependencies": {
        "@dhis2/app-runtime": "^3.17.0",
        "@dhis2/data-engine": "3.17.0",
        "@dhis2/multi-calendar-dates": "^2.1.0",
        "@dhis2/ui": "^10.5.1",
        "@hisptz/dhis2-analytics": "^2.1.35",
        "@hisptz/dhis2-ui": "^2.0.52",
        "@hisptz/dhis2-utils": "^2.0.19",
        "@hookform/resolvers": "^5.2.2",
        "@mantine/colors-generator": "^7.17.5",
        "@mantine/core": "^7.17.4",
        "@mantine/dates": "^7.17.4",
        "@mantine/hooks": "^7.17.4",
        "@mantine/modals": "^7.17.4",
        "@mantine/notifications": "^7.17.4",
        "@mantine/nprogress": "^7.17.4",
        "@next/env": "16.2.3",
        "@packages/shared": "workspace:*",
        "@tabler/icons-react": "^3.31.0",
        "adapter-bun": "github:nnkogift/adapter-bun",
        "canvas": "^3.1.0",
        "chroma-js": "^3.1.2",
        "cypress": "^15.14.1",
        "highcharts": "^12.4.0",
        "highcharts-react-official": "^3.2.2",
        "jszip": "^3.10.1",
        "leaflet": "^1.9.4",
        "leaflet-easyprint": "^2.1.9",
        "lodash-es": "^4.18.1",
        "luxon": "^3.7.2",
        "mammoth": "^1.11.0",
        "manager": "^1.0.9",
        "next": "16.2.3",
        "nextjs-toploader": "^3.8.16",
        "pdfjs-dist": "5.2.133",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-error-boundary": "^5.0.0",
        "react-full-screen": "^1.1.1",
        "react-grid-layout": "^2.2.2",
        "react-hook-form": "^7.72.1",
        "react-jsx-parser": "^2.4.0",
        "react-spring": "^10.0.3",
        "react-svg": "^16.3.0",
        "styled-jsx": "^4.0.1",
        "usehooks-ts": "^3.1.1",
        "xlsx": "^0.18.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cypress/code-coverage": "^3.14.0",
        "@svgr/webpack": "^8.1.0",
        "@tailwindcss/postcss": "^4",
        "@types/chroma-js": "^3.1.1",
        "@types/jszip": "^3.4.1",
        "@types/leaflet": "^1.9.17",
        "@types/lodash-es": "^4.17.12",
        "@types/luxon": "^3.7.1",
        "@types/node": "^20",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "baseline-browser-mapping": "^2.9.14",
        "bestzip": "^2.2.1",
        "cypress-ssr-localhost-mocker": "^0.0.4",
        "eslint": "^9",
        "eslint-config-next": "16.2.3",
        "postcss": "^8.5.3",
        "postcss-preset-mantine": "^1.17.0",
        "postcss-simple-vars": "^7.0.1",
        "tailwindcss": "^4",
        "typescript": "5.6.3"
    }
