
# DHIS2 instance to connect to
DHIS2_BASE_URL=http://172.17.0.1:8080/hmisportal
DHIS2_PAT=<pat-here>
DATA_SERVICE_PORT=3000

SERVE_HTTP=true
# RabbitMQ configuration
RABBITMQ_URI=amqp://guest:guest@rabbitmq:5672
RABBITMQ_HOST=http://rabbitmq:15672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PREFETCH_COUNT=5

 