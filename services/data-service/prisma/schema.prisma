// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RunStatus {
  NOT_STARTED
  IDLE
  RUNNING
  UNKNOWN
  COMPLETED
  FAILED
}

enum ProcessStatus {
  QUEUED
  INIT
  FAILED
  DONE
}

enum UploadStrategy {
  CREATE_AND_UPDATE
  DELETE
}

enum MetadataDownloadType {
  VISUALIZATION
  MAP
  DASHBOARD
}

model DataRun {
  id            Int      @id @default(autoincrement())
  uid           String   @unique @default(cuid())
  startedAt     DateTime @default(now())
  periods       String[]
  timeout       Int?
  parentOrgUnit String?
  orgUnitLevel  Int?
  configIds     String[]
  mainConfigId  String
  isDelete      Boolean  @default(false)

  downloads DataDownload[]
  uploads   DataUpload[]
}

model DataDownload {
  id          Int           @id @default(autoincrement())
  uid         String        @unique @default(cuid())
  runId       Int
  run         DataRun       @relation(fields: [runId], references: [id])
  dimensions  Json
  filters     Json?
  configId    String
  status      ProcessStatus @default(QUEUED)
  startedAt   DateTime?
  finishedAt  DateTime?
  count       Int?
  uploads     DataUpload[]
  error       String?
  errorObject Json?
}

model DataUpload {
  id             Int            @id @default(autoincrement())
  uid            String         @unique @default(cuid())
  filename       String
  runId          Int
  run            DataRun        @relation(fields: [runId], references: [id])
  strategy       UploadStrategy @default(CREATE_AND_UPDATE)
  dataDownloadId Int
  download       DataDownload   @relation(fields: [dataDownloadId], references: [id])
  status         ProcessStatus  @default(QUEUED)
  startedAt      DateTime?
  finishedAt     DateTime?
  count          Int?
  imported       Int?
  ignored        Int?
  updated        Int?
  error          String?
  errorObject    Json?
}

model MetadataRun {
  id           Int      @id @default(autoincrement())
  uid          String   @unique @default(cuid())
  mainConfigId String
  startedAt    DateTime @default(now())

  uploads   MetadataUpload[]
  downloads MetadataDownload[]
}

model MetadataDownload {
  id          Int                  @id @default(autoincrement())
  uid         String               @unique @default(cuid())
  type        MetadataDownloadType
  items       String[]
  runId       Int
  run         MetadataRun          @relation(fields: [runId], references: [id])
  status      ProcessStatus        @default(QUEUED)
  error       String?
  errorObject Json?
  uploads     MetadataUpload[]
}

model MetadataUpload {
  id          Int              @id @default(autoincrement())
  uid         String           @unique @default(cuid())
  filename    String
  runId       Int
  run         MetadataRun      @relation(fields: [runId], references: [id])
  downloadId  Int
  download    MetadataDownload @relation(fields: [downloadId], references: [id])
  status      ProcessStatus    @default(QUEUED)
  error       String?
  errorObject Json?
}
