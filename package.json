{
    "name": "dhis2-public-portal",
    "private": true,
    "scripts": {
        "portal": "pnpm --filter portal",
        "manager": "pnpm --filter manager",
        "docs": "pnpm --filter docs",
        "shared": "pnpm --filter @packages/shared",
        "test": "vitest -c vitest.config.mts",
        "build": "turbo run build",
        "build:standalone": "turbo run build:standalone --filter portal",
        "publish:app-hub": "turbo run publish:app-hub --filter manager",
        "dev": "turbo run dev",
        "dev:portal": "turbo run dev --filter portal",
        "dev:manager": "turbo run dev --filter manager",
        "dev:docs": "turbo run dev --filter docs",
        "deploy": "turbo run deploy",
        "check-types": "turbo run check-types",
        "update-versions": "node scripts/update-versions.js",
        "release": "semantic-release",
        "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
        "clean:cache": "find . -type d -name '.next' -exec rm -rf {} +",
        "lint": "eslint --fix .",
        "lint:check": "turbo run lint:check",
        "format:check": "turbo run format:check",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@dhis2/config-prettier": "^0.2.2",
        "@eslint/compat": "^2.0.1",
        "@eslint/js": "^9.39.2",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/commit-analyzer": "^13.0.1",
        "@semantic-release/exec": "^7.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^11.0.1",
        "@semantic-release/npm": "^12.0.1",
        "@semantic-release/release-notes-generator": "^14.0.3",
        "@types/node": "^25.0.10",
        "eslint": "^9.39.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^16.5.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.0",
        "semantic-release": "^24.2.3",
        "turbo": "^2.7.4",
        "typescript": "5.8.3",
        "typescript-eslint": "^8.53.0",
        "vitest": "^3.1.1"
    },
    "engines": {
        "node": ">=20"
    },
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
    "workspaces": {
        "nohoist": [
            "sharp"
        ],
        "packages": [
            "apps/*",
            "packages/*",
            "services/*"
        ]
    },
    "repository": {
        "url": "git@github.com:hisptz/dhis2-public-portal.git"
    },
    "version": "1.5.4",
    "lint-staged": {
        "**/*.{js,jsx,ts,tsx,json,css,md,yml,mjs,mts}": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "pnpm": {
        "overrides": {
            "@types/react": "19.2.14",
            "@types/react-dom": "19.2.3"
        }
    }
}
